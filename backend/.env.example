# =========================================================================
# Néllia · sousamo — Backend env
# Copia questi valori nella sezione "Environment" del servizio backend
# su EasyPanel. NON committare il file .env reale.
# =========================================================================

# --- App ---
ENVIRONMENT=production
API_PREFIX=/api
# Origini autorizzate (il tuo dominio frontend). Separate da virgola.
CORS_ORIGINS=https://sousamo.com,https://www.sousamo.com
# Token interno per chiamate server->server (genera una stringa random 32+ char)
INTERNAL_API_TOKEN=cambia-con-stringa-random-32-caratteri

# --- Database PostgreSQL (link interno EasyPanel) ---
# Puoi incollare l'URL ESATTAMENTE come te lo da EasyPanel: il backend
# converte da solo lo schema in asyncpg e ignora sslmode.
DATABASE_URL=postgres://sousamo:sousamo@sousamo_dadabis:5432/sousamo?sslmode=disable

# --- Meta (Facebook) Conversions API ---
META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=

# --- TikTok Events API ---
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# --- Snapchat Conversions API ---
SNAP_PIXEL_ID=
SNAP_CAPI_TOKEN=

# --- Google Sheets webhook (Apps Script) ---
SHEETS_WEBHOOK_URL=
# Deve coincidere con SHARED_SECRET in sheets/Code.gs
SHEETS_HMAC_SECRET=genera-secret-condiviso-con-apps-script

# --- Roxod (invio ordini automatico) ---
# URL webhook/API fornito da Roxod quando colleghi il tuo store
ROXOD_WEBHOOK_URL=
# Token API Roxod (se richiesto)
ROXOD_API_KEY=
# SKU prodotto Roxod (Pro Styler)
ROXOD_DEFAULT_SKU=RCOD-GZRLDNKF
# Header auth: Authorization (default) oppure X-Api-Key, ecc.
ROXOD_AUTH_HEADER=Authorization
