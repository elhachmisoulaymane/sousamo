# =========================================================================
# Néllia · sousamo — Frontend env
# Copia questi valori nella sezione "Environment" del servizio frontend
# su EasyPanel. Le variabili NEXT_PUBLIC_* sono visibili nel browser.
# =========================================================================

# URL pubblico del backend API
NEXT_PUBLIC_API_BASE_URL=https://api.sousamo.com
# URL pubblico del sito
NEXT_PUBLIC_SITE_URL=https://sousamo.com

NEXT_PUBLIC_ENVIRONMENT=production

# --- ID Pixel (lato browser) ---
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=

# --- Privata (solo server, non esposta al browser) ---
INTERNAL_API_TOKEN=stesso-token-del-backend
